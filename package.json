{
  "name": "molinword",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "api": "node server/index.js",
    "build": "tsc -b && vite build",
    "check:docx-export-format": "node scripts/check-docx-export-format.mjs",
    "check:docx-import-format": "node scripts/check-docx-import-format.mjs",
    "check:editor-workflow": "npm run build && node scripts/check-editor-workflow.mjs",
    "check:editor-pagination": "npm run check:editor-workflow",
    "db:migrate:document-template": "node database/migrate-document-template-binding.mjs",
    "db:seed:templates": "node database/seed-document-templates.mjs",
    "template-agent": "node scripts/template-agent.mjs",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/extension-table": "^3.27.1",
    "@tiptap/extension-table-cell": "^3.27.1",
    "@tiptap/extension-table-header": "^3.27.1",
    "@tiptap/extension-table-row": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@vitejs/plugin-react": "^5.0.0",
    "docx": "^9.7.1",
    "dotenv": "^17.0.0",
    "express": "^5.0.0",
    "htmlparser2": "^12.0.0",
    "image-size": "^2.0.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "mammoth": "^1.10.0",
    "minio": "^8.0.7",
    "multer": "^2.0.2",
    "mysql2": "^3.22.5",
    "pdf-parse": "^1.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sanitize-html": "^2.17.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "word-extractor": "^1.0.4"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "playwright": "^1.61.1"
  }
}
