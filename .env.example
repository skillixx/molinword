# Moling platform
# 墨灵平台 API 地址，用于后续 SSO 校验、计费、资产/额度查询。
MOLING_API_BASE_URL=http://8.130.9.163:8080
# 墨灵内部接口令牌，用于调用 /api/internal/*，只能放服务端，不能暴露到浏览器。
INTERNAL_API_TOKEN=replace-with-internal-token
# 是否启用本地模拟墨灵平台。false 表示调用真实墨灵平台。
LOCAL_MOLING_MOCK=false

# Application runtime
# 当前运行环境：development / test / production。
APP_ENV=development
# 应用名称，用于日志、健康检查和部署识别。
APP_NAME=moling_word
# 应用服务端口，正式后端服务可使用；当前本地 API 代理优先使用 LOCAL_API_PORT。
APP_PORT=5778
# 本地 Node API 代理端口，前端 /api 请求会转发到这里。
LOCAL_API_PORT=3001
# Cookie 是否只允许 HTTPS 传输。本地开发用 false，生产环境建议 true。
SESSION_COOKIE_SECURE=false
# 登录会话有效期，单位秒。86400 表示 1 天。
SESSION_TTL_SECONDS=86400
# 应用前端访问地址，用于生成回调、跳转、下载链接等。
APP_BASE_URL=http://127.0.0.1:5173
# 墨灵平台中的应用 ID，正式 SSO 和计费时使用。
MOLING_APP_ID=15
# 墨灵平台中绑定本应用的商品 ID，正式使用权校验和计费时使用。
MOLING_PRODUCT_ID=73
# 墨灵 user_id 与 entitlement_id 的映射，格式：userId:entitlementId,userId:entitlementId。
MOLING_USER_ENTITLEMENT_MAP=
# 默认 entitlement_id，找不到用户映射时可作为兜底；为空表示不兜底。
MOLING_DEFAULT_ENTITLEMENT_ID=

# Compatibility aliases for Moling deployment commands.
# 兼容部署平台常用 PORT 变量，留空表示使用 APP_PORT 或 LOCAL_API_PORT。
PORT=
# Word 项目专用 app_id 别名。
WORD_APP_ID=15
# Word 项目专用 product_id 别名。
WORD_PRODUCT_ID=73
# Word 项目专用默认 entitlement_id 别名。
WORD_DEFAULT_ENTITLEMENT_ID=
# PPT 项目兼容变量，本项目一般不使用，保留是为了兼容已有部署脚本。
PPT_APP_ID=
PPT_PRODUCT_ID=
PPT_DEFAULT_ENTITLEMENT_ID=

# AI provider
# AI 提供商类型。http 表示直接调用 OpenAI 兼容 HTTP 接口。
LLM_PROVIDER=http
# AI chat/completions 接口地址。
LLM_API_URL=https://api.deepseek.com/chat/completions
# AI 接口密钥，只能服务端使用，不能暴露到前端。
LLM_API_KEY=replace-with-llm-api-key
# 默认文字模型，用于生成大纲、正文、润色等。
LLM_MODEL=deepseek-v4-flash
# AI 请求超时时间，单位毫秒。
LLM_TIMEOUT_MS=30000
# AI 请求失败后的最大重试次数。
LLM_MAX_RETRIES=1

# OpenAI-compatible aliases used by the current local API proxy.
# 墨灵 Token 网关 OpenAI 兼容 base URL。如果改走墨灵网关，可配到 /v1。
MOLIN_GATEWAY_BASE_URL=http://8.130.9.163:8080/v1
# 墨灵 Token 网关 sk。当前优先使用 LLM_API_KEY，此项可留空。
MOLIN_GATEWAY_API_KEY=
# 墨灵 Token 网关模型别名。当前优先使用 LLM_MODEL。
MOLIN_GATEWAY_MODEL=deepseek-v4-flash

# Optional image service
# 图片生成/识别服务提供商。当前第一版不需要，可留空。
IMAGE_PROVIDER=
# 图片服务密钥。当前第一版不需要，可留空。
IMAGE_API_KEY=

# Database / storage
# MySQL 连接字符串。Word 项目使用独立库 moling_word 和独立账号 moling_word_app。
DATABASE_URL=mysql://moling_word_app:replace-with-password@127.0.0.1:3306/moling_word
# 本地文件存储目录。使用 MinIO 时可留空。
STORAGE_DIR=
# MinIO 服务地址。
STORAGE_ENDPOINT=http://127.0.0.1:9000
# MinIO bucket 名称，用于保存 Word 上传文件、图片和导出文件。
STORAGE_BUCKET=moling-word
# MinIO access key。
STORAGE_ACCESS_KEY_ID=replace-with-minio-access-key
# MinIO secret key，只能服务端使用。
STORAGE_SECRET_ACCESS_KEY=replace-with-minio-secret-key
